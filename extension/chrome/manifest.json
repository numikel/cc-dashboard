{
  "manifest_version": 3,
  "name": "CC dashboard",
  "description": "Side panel for a local Claude Code usage dashboard.",
  "version": "0.3.0",
  "minimum_chrome_version": "114",
  "permissions": ["sidePanel", "storage"],
  "host_permissions": ["http://localhost/*", "http://127.0.0.1/*"],
  "action": {
    "default_title": "Open CC dashboard"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
