APP_VERSION=0.2.0
HOST_PORT=3000
PORT=3000
HOST=127.0.0.1

# Native local runtime defaults. Docker overrides these values inside the container.
DATA_DIR=./data
DATABASE_PATH=./data/dashboard.db
# Optional guard for managed single-process runtimes such as WinSW services.
# Keep disabled for Next.js dev and normal npm starts.
CC_DASHBOARD_ENABLE_DB_LOCK=0

# Use forward slashes on Windows, for example:
# CLAUDE_DATA_PATH=C:/Users/micha/.claude
CLAUDE_DATA_PATH=
# CLAUDE_CONFIG_DIR takes precedence when your Claude Code config lives outside the default path.
CLAUDE_CONFIG_DIR=

# Allowed values: 0, 30, 60, 180, 300. 0 means OFF.
REFRESH_INTERVAL=60

# Optional, development only. Use when opening next dev through a LAN address.
# Example: ALLOWED_DEV_ORIGINS=192.168.1.22
ALLOWED_DEV_ORIGINS=

# Plan usage panel tries the official Anthropic OAuth usage endpoint first.
# If credentials or API access are unavailable, these local estimate budgets are used.
PLAN_SESSION_TOKEN_BUDGET=1000000
PLAN_WEEKLY_TOKEN_BUDGET=5000000
PLAN_WEEKLY_SONNET_TOKEN_BUDGET=5000000
PLAN_DAILY_ROUTINE_LIMIT=15
